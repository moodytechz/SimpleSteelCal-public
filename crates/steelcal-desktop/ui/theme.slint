// ---------------------------------------------------------------------------
// Theme – global color / spacing properties
// ---------------------------------------------------------------------------

export global Theme {
    // Primary brand colors
    out property <color> primary: #2c5f7c;
    out property <color> primary-light: #3a7ca5;
    out property <color> primary-dark: #1e4358;

    // Background colors
    out property <color> background: #f5f6f8;
    out property <color> surface: #ffffff;
    out property <color> surface-alt: #eef1f4;

    // Text colors
    out property <color> text-primary: #1a2b36;
    out property <color> text-secondary: #4f5c65;
    out property <color> text-muted: #8a949c;

    // Accent / feedback
    out property <color> accent: #d4830a;
    out property <color> error: #c0392b;
    out property <color> success: #27ae60;

    // Spacing / sizing
    out property <length> spacing-sm: 8px;
    out property <length> spacing-md: 16px;
    out property <length> spacing-lg: 24px;
    out property <length> spacing-xl: 32px;

    // Border
    out property <color> border: #d0d5da;
    out property <length> border-radius: 6px;
}
